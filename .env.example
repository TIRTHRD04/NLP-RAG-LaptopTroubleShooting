# .env.example
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env

# === API Keys (Get these from respective platforms) ===
# Groq API Key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# === Model Configuration ===
# Embedding model from HuggingFace
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# LLM model on Groq platform
LLM_MODEL=llama-3.1-8b-instant

# === Qdrant Vector Database (Running locally via Docker) ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Name of the collection to store our troubleshooting data
COLLECTION_NAME=laptop_troubleshooting

# === Data Paths ===
# Where your preprocessed .txt files are stored
# DATA_DIR=./data/raw
DATA_DIR=./data/processed

# Optional: cache directory for processed data
PROCESSED_DIR=./data/processed

# === Retrieval Settings ===
# Number of chunks to retrieve for answering a question
TOP_K=5
# Minimum similarity score (0.0 to 1.0) to include a result
SCORE_THRESHOLD=0.7

# === LLM Generation Settings ===
# Lower = more deterministic, higher = more creative
LLM_TEMPERATURE=0.1
# Max tokens in the generated answer
LLM_MAX_TOKENS=1024

# === Logging ===
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log