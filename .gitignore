# .gitignore

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# === Virtual Environments ===
venv/
ENV/
env/
.venv/

# === IDE ===
.idea/
.vscode/
*.swp
*.swo

# === Environment & Secrets ===
.env
*.key
*.pem

# === Logs ===
logs/
*.log

# === Data (don't commit large files) ===
data/raw/*.txt
data/processed/

# === Qdrant storage (if using local volume) ===
qdrant_storage/

# === OS ===
.DS_Store
Thumbs.db

steps.txt
Project_Flow.md